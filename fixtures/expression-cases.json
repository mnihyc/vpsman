    },
    "hidden": {
      "hidden": true,
      "vps": {
        "id": "hidden-01",
        "display_name": "Hidden One",
        "status": "online",
        "tags": ["edge"],
        "last_seen_at": "2026-06-08T01:00:00Z",
        "internal_build_number": 42
      },
      "event_predicates": ["interval.30sec"],
      "job": {},
