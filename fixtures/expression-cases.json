  "cases": [
    { "name": "precedence_or_after_and", "expression": "provider:alpha || provider:beta && status:stale", "matches": ["edge", "core"] },
    { "name": "not_and_implicit_and", "expression": "status:online !provider:beta", "matches": ["edge", "hidden"] },
    { "name": "tilde_not", "expression": "~tag:prod", "matches": ["core", "untagged", "hidden"] },
    { "name": "explicit_and_or_grouping", "expression": "(provider:alpha || provider:beta) && country:US", "matches": ["edge"] },
    { "name": "comparisons", "expression": "vps.internal_build_number >= 40 && last_seen < 2026-06-08T02:00:00Z", "matches": ["edge", "hidden"] },
    { "name": "in_and_not_in", "expression": "status in [online, stale] && vps.tag not in [prod]", "matches": ["core", "hidden"] },
    { "name": "regex_list", "expression": "vps.tag in [/^provider:a.*/, edge]", "matches": ["edge", "hidden"] },
    { "name": "quoted_values", "expression": "name = \"Edge One\"", "matches": ["edge"] },
    { "name": "aliases", "expression": "region:US && id:edge-*", "matches": ["edge"] },
    { "name": "untagged", "expression": "untagged", "matches": ["untagged"] },
    { "name": "missing_metadata", "expression": "vps.stale_reason = manual", "matches": [] },
    { "name": "event_predicates", "expression": "interval.30sec && job.status:running && alert.open", "matches": ["edge"] },
    { "name": "event_object_fields", "expression": "job.status = running && alert.severity = critical", "matches": ["edge"] }
  ]
}
