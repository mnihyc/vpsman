POSTGRES_DB=vpsman
POSTGRES_USER=vpsman
POSTGRES_PASSWORD=replace-with-random-postgres-password

# Compose mounts ./config to /etc/vpsman and sets VPSMAN_SUITE_CONFIG to
# /etc/vpsman/vpsman.toml. The API can replace that authoritative TOML through
# the dashboard. Secret files are mounted per service under /run/secrets so
# API and worker containers do not receive gateway-only key material.
# Put secret contents in files referenced by the TOML, for example:
# ./config/secrets/vpsman_internal_token
# ./config/secrets/vpsman_gateway_private_key_hex
# ./config/secrets/vpsman_privilege_verifier_key_hex
