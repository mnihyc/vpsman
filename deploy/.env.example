# vpsman compose environment template.
# Copy to deploy/.env, fill every required secret, and keep deploy/.env out of git.

# PostgreSQL service. The default URL below matches the compose service names.
POSTGRES_DB=vpsman
POSTGRES_USER=vpsman
POSTGRES_PASSWORD=vpsman
VPSMAN_POSTGRES_URL=postgres://vpsman:vpsman@postgres:5432/vpsman
VPSMAN_MIGRATIONS_DIR=/opt/vpsman/migrations

# Public API and private gateway-control wiring.
VPSMAN_API_BIND=0.0.0.0:8080
VPSMAN_API_URL=http://api:8080
VPSMAN_GATEWAY_CONTROL_URL=http://gateway:9444
VPSMAN_GATEWAY_BIND=0.0.0.0:9443
VPSMAN_GATEWAY_CONTROL_BIND=0.0.0.0:9444
VPSMAN_GATEWAY_ID=compose-gateway
VPSMAN_GATEWAY_RECONNECT_GRACE_SECS=120

# Required shared internal token used only between API, gateway, and worker.
# Generate a random value of at least 32 characters, for example:
#   python3 - <<'PY'
#   import secrets; print(secrets.token_urlsafe(48))
#   PY
VPSMAN_INTERNAL_TOKEN=

# Required server Ed25519 job-signing key. The private key is passed only to API
# and worker. Give agents the corresponding public key as
# VPSMAN_SERVER_ED25519_PUBLIC_KEY_HEX when rendering their agent.toml.
# Generate with:
#   vpsctl signing-keygen
VPSMAN_SERVER_SIGNING_KEY_HEX=

# Required gateway Noise identity. The private key stays on the gateway. Give
# agents the corresponding public key as VPSMAN_GATEWAY_SERVER_PUBLIC_KEY_HEX.
# Generate with:
#   vpsctl noise-keygen
VPSMAN_GATEWAY_NOISE_MODE=enrolled_ik
VPSMAN_GATEWAY_PRIVATE_KEY_HEX=
# Leave empty for normal registered-agent fleets. Set only for a single pinned
# client public key deployment.
VPSMAN_GATEWAY_EXPECT_CLIENT_PUBLIC_KEY_HEX=

# Required gateway-only verifier for privileged operations. Compose passes this
# only to the private gateway service; it must never be passed to the API.
#
# Generate it with vpsctl in an operator shell:
#   export VPSMAN_SUPER_PASSWORD='<operator-super-password>'
#   vpsctl privilege-verifier --generate-salt
#
# The command prints both:
#   - super_salt_hex: keep this with operator-side panel/CLI unlock material.
#   - privilege_verifier_key_hex: paste only this value below.
#
# To reproduce the same verifier later, reuse the same password and salt:
#   export VPSMAN_SUPER_PASSWORD='<operator-super-password>'
#   vpsctl privilege-verifier --super-salt-hex '<super_salt_hex>'
#
# Derivation is SHA256("vpsman-super-key-v1" || uint64_be(len(salt)) ||
# salt || utf8(password)). Agents never receive password, salt, or verifier.
VPSMAN_PRIVILEGE_VERIFIER_KEY_HEX=

# Local filesystem-backed object storage is the default deployment shape.
# Docker note: keep these container paths unchanged; compose maps them to
# ./runtime/data.
VPSMAN_BACKUP_OBJECT_STORE_DIR=/var/lib/vpsman/objects/backups
VPSMAN_BACKUP_UPLOAD_STAGING_DIR=/var/lib/vpsman/objects/backups/.upload-sessions
VPSMAN_UPDATE_OBJECT_STORE_DIR=/var/lib/vpsman/objects/updates
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_OBJECT_STORE_DIR=/var/lib/vpsman/objects/backups

# Optional S3/MinIO adapter path. Leave endpoint/bucket/access/secret empty for
# local filesystem storage. Example MinIO values: endpoint http://minio:9000,
# backup bucket vpsman-artifacts, update bucket vpsman-updates, access/secret
# change-me, region us-east-1, create bucket true.
VPSMAN_OBJECT_ENDPOINT=
VPSMAN_OBJECT_BUCKET=
VPSMAN_OBJECT_ACCESS_KEY=
VPSMAN_OBJECT_SECRET_KEY=
VPSMAN_OBJECT_REGION=us-east-1
VPSMAN_OBJECT_CREATE_BUCKET=false
VPSMAN_UPDATE_OBJECT_ENDPOINT=
VPSMAN_UPDATE_OBJECT_BUCKET=
VPSMAN_UPDATE_OBJECT_ACCESS_KEY=
VPSMAN_UPDATE_OBJECT_SECRET_KEY=
VPSMAN_UPDATE_OBJECT_REGION=us-east-1
VPSMAN_UPDATE_OBJECT_CREATE_BUCKET=false

# Agent-update artifact policy. Jobs are direct privileged jobs that dispatch
# to resolved targets and report progress through normal job polling.
VPSMAN_UPDATE_ARTIFACT_PUBLIC_BASE_URL=
VPSMAN_AGENT_UPDATE_ALLOWED_CHANNELS=
VPSMAN_AGENT_UPDATE_TRUSTED_SIGNING_KEYS_HEX=
VPSMAN_REQUIRE_REGISTERED_AGENT_UPDATES=false

# Job output artifact offload threshold.
VPSMAN_JOB_OUTPUT_ARTIFACT_MIN_BYTES=32768

# Fleet alert thresholds.
VPSMAN_ALERT_MEMORY_AVAILABLE_WARNING_RATIO=0.20
VPSMAN_ALERT_MEMORY_AVAILABLE_CRITICAL_RATIO=0.10
VPSMAN_ALERT_DISK_AVAILABLE_WARNING_RATIO=0.20
VPSMAN_ALERT_DISK_AVAILABLE_CRITICAL_RATIO=0.10
VPSMAN_ALERT_CPU_LOAD_WARNING=2.0
VPSMAN_ALERT_CPU_LOAD_CRITICAL=4.0

# Worker cadence, leases, schedule dispatch, notifications, webhook-rule
# materialization/delivery, and backup-retention pruning.
VPSMAN_WORKER_TICK_SECS=30
VPSMAN_WORKER_ID=
VPSMAN_WORKER_LEASE_SECS=60
VPSMAN_AGENT_OFFLINE_TIMEOUT_SECS=300
VPSMAN_WORKER_SCHEDULE_COMMAND_TIMEOUT_SECS=30
VPSMAN_WORKER_NOTIFICATION_DELIVERY_LIMIT=25
VPSMAN_WORKER_NOTIFICATION_RETENTION_DAYS=90
VPSMAN_WORKER_NOTIFICATION_RETENTION_PRUNE_LIMIT=1000
VPSMAN_WORKER_NOTIFICATION_WEBHOOK_TIMEOUT_SECS=5
VPSMAN_WORKER_WEBHOOK_RULE_DELIVERY_LIMIT=25
VPSMAN_WORKER_WEBHOOK_RULE_MATERIALIZE_LIMIT=100
VPSMAN_WORKER_WEBHOOK_RULE_RETENTION_DAYS=90
VPSMAN_WORKER_WEBHOOK_RULE_RETENTION_PRUNE_LIMIT=1000
VPSMAN_WORKER_WEBHOOK_RULE_TIMEOUT_SECS=5
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_ENABLED=false
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_LIMIT=50
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_DRY_RUN=false
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_INCLUDE_DISABLED=false
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_DELETE_OBJECTS=false

# Internal test mode must stay false outside local debug smokes.
VPSMAN_DEBUG_INTERNAL_TEST_MODE=false
