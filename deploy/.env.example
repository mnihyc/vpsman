POSTGRES_DB=vpsman
POSTGRES_USER=vpsman
POSTGRES_PASSWORD=vpsman
VPSMAN_API_BIND=0.0.0.0:8080
VPSMAN_API_URL=http://api:8080
VPSMAN_INTERNAL_TOKEN=replace-with-random-token-at-least-32-chars
VPSMAN_GATEWAY_CONTROL_URL=http://gateway:9444
# Placeholder only. Generate a real 32-byte Ed25519 signing key for deployments.
VPSMAN_SERVER_SIGNING_KEY_HEX=
VPSMAN_GATEWAY_BIND=0.0.0.0:9443
VPSMAN_GATEWAY_CONTROL_BIND=0.0.0.0:9444
VPSMAN_GATEWAY_NOISE_MODE=dev_xx
# Public remote-agent deployments must use enrolled_ik, not dev_xx.
# Set these for VPSMAN_GATEWAY_NOISE_MODE=enrolled_ik.
VPSMAN_GATEWAY_PRIVATE_KEY_HEX=
# Leave empty for normal fleets; the gateway asks the API to validate enrolled
# client keys. Set only for a single pinned client deployment.
VPSMAN_GATEWAY_EXPECT_CLIENT_PUBLIC_KEY_HEX=
VPSMAN_GATEWAY_SERVER_PUBLIC_KEY_HEX=
# Public endpoints use label=host:port=priority and are embedded in enrollment
# configs as raw TCP gateway addresses. Do not add http:// or https:// here.
# Keep 9444 private; expose/proxy only the agent TCP gateway on 9443.
# VPSMAN_PUBLIC_GATEWAY_ENDPOINTS=public=your-gateway.example:9443=10
# VPSMAN_DISCOVERY_URL=https://panel.example.com/.well-known/vpsman/endpoints.json
VPSMAN_POSTGRES_URL=postgres://vpsman:vpsman@postgres:5432/vpsman
VPSMAN_MIGRATIONS_DIR=/opt/vpsman/migrations
# Local filesystem-backed object storage is the default deployment shape.
# Docker note: keep these container paths unchanged; compose maps them to
# ./runtime/data.
VPSMAN_BACKUP_OBJECT_STORE_DIR=/var/lib/vpsman/objects/backups
VPSMAN_WORKER_BACKUP_POLICY_PRUNE_OBJECT_STORE_DIR=/var/lib/vpsman/objects/backups
VPSMAN_UPDATE_OBJECT_STORE_DIR=/var/lib/vpsman/objects/updates

# Optional S3/MinIO adapter path. Leave unset for local filesystem storage.
# VPSMAN_OBJECT_ENDPOINT=http://minio:9000
# VPSMAN_OBJECT_BUCKET=vpsman-artifacts
# VPSMAN_OBJECT_ACCESS_KEY=change-me
# VPSMAN_OBJECT_SECRET_KEY=change-me
# VPSMAN_OBJECT_REGION=us-east-1
# VPSMAN_OBJECT_CREATE_BUCKET=true
# VPSMAN_UPDATE_OBJECT_ENDPOINT=http://minio:9000
# VPSMAN_UPDATE_OBJECT_BUCKET=vpsman-updates
# VPSMAN_UPDATE_OBJECT_ACCESS_KEY=change-me
# VPSMAN_UPDATE_OBJECT_SECRET_KEY=change-me
# VPSMAN_UPDATE_OBJECT_REGION=us-east-1
# VPSMAN_UPDATE_OBJECT_CREATE_BUCKET=true
